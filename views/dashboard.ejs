<%- include('header') %>
<body class="bg-gray-50 min-h-screen flex flex-col">
  <%- include('navbar') %>

  <div class="max-w-5xl mx-auto px-4 py-8 flex-1 w-full">
    <!-- Page Title -->
    <h1 class="text-3xl font-bold text-blue-600 mb-6">Dashboard</h1>

    <!-- Welcome Section -->
    <div class="bg-white rounded-lg shadow p-4 mb-6">
      <h2 class="text-xl font-semibold text-gray-800 mb-1">Welcome, <strong><%= user.name %></strong>!</h2>
      <p class="text-sm text-gray-600">Your wallet summary and recent activity</p>
    </div>

    <% if (user && user.wallet) { %>
      <!-- Wallet Card -->
      <div class="bg-gradient-to-br from-blue-600 to-purple-700 text-white rounded-lg shadow p-6 mb-6">
        <h2 class="text-lg mb-2 opacity-90">Your Wallet Balance</h2>
        <div class="text-4xl font-bold mb-2">Rp <%= user.wallet.balance.toLocaleString('id-ID') %></div>
        <p class="text-sm opacity-75">Account Balance</p>
      </div>

      <!-- Action Buttons Grid -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-2 mb-6">
        <a href="/transfers" class="bg-white hover:shadow p-4 rounded text-center">
          <div class="text-2xl mb-1">🔄</div>
          <div class="text-sm font-semibold text-gray-800">Transfer</div>
        </a>
        <a href="/merchants" class="bg-white hover:shadow p-4 rounded text-center">
          <div class="text-2xl mb-1">🛍️</div>
          <div class="text-sm font-semibold text-gray-800">Pay</div>
        </a>
        <a href="/transactions" class="bg-white hover:shadow p-4 rounded text-center">
          <div class="text-2xl mb-1">📊</div>
          <div class="text-sm font-semibold text-gray-800">History</div>
        </a>
      </div>

      <!-- Recent Transactions -->
      <% if (user.wallet.transactions && user.wallet.transactions.length > 0) { %>
        <div class="bg-white rounded-lg shadow overflow-hidden">
          <div class="p-3 border-b bg-blue-50">
            <h2 class="text-lg font-bold text-blue-600">Recent Transactions</h2>
          </div>
          <div class="divide-y">
            <% user.wallet.transactions.forEach(txn => { %>
              <div class="p-3 text-sm hover:bg-gray-50 flex justify-between">
                <div>
                  <strong class="text-gray-800"><%= txn.direction || txn.description %></strong>
                  <br>
                  <small class="text-gray-500"><%= new Date(txn.createdAt).toLocaleDateString('id-ID') %></small>
                </div>
                <span class="<%= txn.type === 'debit' ? 'bg-red-100 text-red-700' : 'bg-green-100 text-green-700' %> px-2 py-1 rounded font-semibold">
                  <%= txn.type === 'debit' ? '−' : '+' %> Rp <%= (txn.amount).toLocaleString('id-ID') %>
                </span>
              </div>
            <% }); %>
          </div>
        </div>
      <% } else { %>
        <div class="bg-white rounded-lg shadow p-6 text-center">
          <p class="text-4xl mb-2">📭</p>
          <p class="text-gray-500 mb-3">No transactions yet</p>
          <div class="flex gap-2 justify-center flex-wrap">
            <a href="/transfers" class="px-3 py-2 bg-blue-600 text-white rounded text-sm hover:bg-blue-700">Transfer</a>
            <a href="/merchants" class="px-3 py-2 bg-blue-600 text-white rounded text-sm hover:bg-blue-700">Pay Merchant</a>
          </div>
        </div>
      <% } %>
    <% } %>
  </div>

  <%- include('footer') %>
</body>
</html>

<%- include('header') %>
<body class="bg-gradient-to-br from-blue-500 via-blue-600 to-purple-700 min-h-screen flex items-center justify-center p-4">
  <div class="w-full max-w-md bg-white rounded-lg shadow-2xl p-8 text-center">
    <!-- Error Icon -->
    <div class="text-7xl mb-4">⚠️</div>
    
    <!-- Error Title -->
    <h1 class="text-3xl font-bold text-red-600 mb-2"><%= title || 'Error' %></h1>
    
    <!-- Error Message -->
    <p class="text-gray-600 leading-relaxed mb-6">
      <%= message %>
    </p>

    <!-- Error Details -->
    <% if (error && error.message) { %>
      <div class="bg-gray-100 border-l-4 border-red-600 p-4 rounded mb-6 text-left text-sm text-gray-700">
        <strong class="block mb-2 text-red-600">Technical Details:</strong>
        <code class="text-xs"><%= error.message %></code>
      </div>
    <% } %>

    <!-- Action Buttons -->
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <button 
        onclick="history.back()" 
        class="px-6 py-2 bg-gray-600 text-white font-semibold rounded-lg hover:bg-gray-700 transition"
      >
        ← Go Back
      </button>
      <button 
        onclick="location.href='/'" 
        class="px-6 py-2 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition"
      >
        🏠 Home
      </button>
    </div>
  </div>

  <%- include('footer') %>
</body>
</html>

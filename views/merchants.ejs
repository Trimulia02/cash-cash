<%- include('header') %>
<body class="bg-gray-50 min-h-screen flex flex-col">
  <%- include('navbar') %>

  <div class="max-w-5xl mx-auto px-4 py-8 flex-1 w-full">
    <h1 class="text-3xl font-bold text-blue-600 mb-6">🛍️ Pay Merchants</h1>

    <!-- Search Form -->
    <div class="bg-white rounded-lg shadow p-4 mb-6">
      <form class="flex gap-2" action="/merchants" method="GET">
        <input
          type="text"
          name="category"
          value="<%= category || '' %>"
          placeholder="Search by category..."
          class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600"
        >
        <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
          Search
        </button>
        <% if (category) { %>
          <a href="/merchants" class="px-6 py-2 border border-gray-300 rounded-lg hover:bg-gray-100">
            Clear
          </a>
        <% } %>
      </form>
    </div>

    <!-- Show Message if Error -->
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-100 border border-red-400 text-red-700 p-4 mb-6 rounded">
        <%= error %>
      </div>
    <% } %>

    <!-- Merchants Grid -->
    <% if (typeof merchants !== 'undefined' && merchants && merchants.length > 0) { %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
        <% merchants.forEach(merchant => { %>
          <div class="bg-white rounded-lg shadow p-4">
            <h3 class="text-lg font-bold text-gray-800 mb-2"><%= merchant.name %></h3>
            <p class="text-sm text-gray-500 mb-3"><%= merchant.category || 'General' %></p>
            
            <form class="merchant-pay-form flex gap-2" data-merchant-id="<%= merchant.id %>">
              <input 
                type="number" 
                placeholder="Amount" 
                min="10000" 
                required
                class="flex-1 px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-600 text-sm"
              >
              <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 text-sm">
                Pay
              </button>
            </form>
          </div>
        <% }); %>
      </div>

      <!-- Pagination -->
      <% if (typeof pagination !== 'undefined' && pagination) { %>
        <div class="flex justify-center gap-2">
          <% if (pagination.hasPrevPage) { %>
            <a href="?page=<%= pagination.page - 1 %><%= category ? '&category=' + encodeURIComponent(category) : '' %>" class="px-4 py-2 border border-blue-600 text-blue-600 rounded hover:bg-blue-50">
              Previous
            </a>
          <% } %>

          <span class="px-4 py-2 bg-blue-600 text-white rounded">
            Page <%= pagination.page %> of <%= pagination.pages %>
          </span>

          <% if (pagination.hasNextPage) { %>
            <a href="?page=<%= pagination.page + 1 %><%= category ? '&category=' + encodeURIComponent(category) : '' %>" class="px-4 py-2 border border-blue-600 text-blue-600 rounded hover:bg-blue-50">
              Next
            </a>
          <% } %>
        </div>
      <% } %>
    <% } else { %>
      <div class="bg-white rounded-lg shadow p-8 text-center">
        <p class="text-5xl mb-4">🏪</p>
        <p class="text-gray-500 text-lg">No merchants found</p>
        <a href="/merchants" class="mt-4 inline-block px-6 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
          View All Merchants
        </a>
      </div>
    <% } %>
  </div>

  <div>
    <button class="button">Tambah</button>
  </div>

  <script>
    document.querySelectorAll('.merchant-pay-form').forEach(form => {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const merchantId = parseInt(form.dataset.merchantId, 10);
        const amount = parseInt(form.querySelector('input[type="number"]').value, 10);

        if (!merchantId || merchantId < 1 || !amount || amount < 10000) {
          alert('Invalid amount (minimum Rp 10.000)');
          return;
        }

        try {
          const res = await fetch('/payments/create', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ merchantId, amount })
          });
          const data = await res.json();

          if (data.success) {
            alert('Payment successful!');
            location.reload();
          } else {
            alert('Payment failed: ' + data.message);
          }
        } catch (err) {
          alert('Error: ' + err.message);
        }
      });
    });
  </script>

  <%- include('footer') %>
</body>
</html>

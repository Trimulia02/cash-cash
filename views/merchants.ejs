<%- include('header') %>
<body class="bg-gray-50">
  <%- include('navbar') %>

  <div class="max-w-6xl mx-auto px-4 py-8">
    <!-- Page Title -->
    <h1 class="text-4xl font-bold text-blue-600 mb-8">🛍️ Merchants</h1>

    <% const currentCategory = typeof category !== 'undefined' ? category : ''; %>
    <% const hasError = typeof error !== 'undefined' && error; %>
    <% const hasMerchants = typeof merchants !== 'undefined' && Array.isArray(merchants) && merchants.length > 0; %>
    <% const hasPagination = typeof pagination !== 'undefined' && pagination; %>
    <% const categoryQuery = currentCategory ? '&category=' + encodeURIComponent(currentCategory) : ''; %>

    <!-- Search Form -->
    <form class="bg-white rounded-lg shadow-md p-6 mb-8 flex flex-col sm:flex-row gap-4" action="/merchants" method="GET">
      <input
        type="text"
        name="category"
        value="<%= currentCategory %>"
        placeholder="Filter by category (e.g. Food, Retail, Telecom)"
        class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600"
      >
      <button type="submit" class="px-6 py-2 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition">
        🔍 Search
      </button>
      <% if (currentCategory) { %>
        <a href="/merchants" class="px-6 py-2 border-2 border-gray-300 text-gray-700 font-semibold rounded-lg hover:border-red-600 hover:text-red-600 transition">
          ✕ Clear
        </a>
      <% } %>
    </form>

    <!-- Error Message -->
    <% if (hasError) { %>
      <div class="bg-red-100 border-l-4 border-red-600 text-red-700 p-4 mb-8 rounded">
        <strong>Error:</strong> <%= error %>
      </div>
    <% } %>

    <!-- Merchants Grid -->
    <% if (hasMerchants) { %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
        <% merchants.forEach(function(merchant) { %>
          <div class="bg-white rounded-lg shadow-md hover:shadow-lg hover:-translate-y-1 transition p-6">
            <div class="text-3xl mb-3">🏪</div>
            <h3 class="text-xl font-bold text-blue-600 mb-2"><%= merchant.name %></h3>
            <span class="inline-block px-3 py-1 bg-gray-100 text-gray-700 text-sm font-semibold rounded mb-4">
              <%= merchant.category || 'General' %>
            </span>
            <p class="text-gray-600 mb-6">
              Pay <%= merchant.name %> from your wallet
            </p>
            <form class="flex gap-2 merchant-pay-form" data-merchant-id="<%= merchant.id %>">
              <input 
                type="number" 
                placeholder="Amount" 
                min="10000" 
                required
                class="flex-1 px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600 text-sm"
              >
              <button 
                type="submit"
                class="px-4 py-2 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition text-sm"
              >
                Pay
              </button>
            </form>
          </div>
        <% }); %>
      </div>

      <!-- Pagination -->
      <% if (hasPagination) { %>
        <div class="flex items-center justify-center gap-2">
          <% if (pagination.hasPrevPage) { %>
            <a href="?page=<%= pagination.page - 1 %><%= categoryQuery %>" class="px-4 py-2 border border-blue-600 text-blue-600 rounded-lg hover:bg-blue-50 transition">
              ← Previous
            </a>
          <% } %>

          <span class="px-4 py-2 bg-blue-600 text-white rounded-lg font-semibold">
            Page <%= pagination.page %> of <%= pagination.pages %>
          </span>

          <% if (pagination.hasNextPage) { %>
            <a href="?page=<%= pagination.page + 1 %><%= categoryQuery %>" class="px-4 py-2 border border-blue-600 text-blue-600 rounded-lg hover:bg-blue-50 transition">
              Next →
            </a>
          <% } %>
        </div>
      <% } %>
    <% } else { %>
      <div class="bg-white rounded-lg shadow-md p-12 text-center">
        <div class="text-5xl mb-4">🏪</div>
        <p class="text-gray-500 text-lg">No merchants found</p>
        <a href="/merchants" class="mt-4 inline-block px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">
          View All Merchants
        </a>
      </div>
    <% } %>
  </div>

  <script>
    document.querySelectorAll('.merchant-pay-form').forEach(function(form) {
      form.addEventListener('submit', function(e) {
        const merchantId = parseInt(form.dataset.merchantId, 10);
        payMerchant(e, merchantId);
      });
    });

    function payMerchant(e, merchantId) {
      e.preventDefault();
      if (Number.isNaN(merchantId) || merchantId < 1) {
        alert('❌ Merchant ID tidak valid');
        return;
      }

      const amountInput = e.target.querySelector('input[type="number"]');
      const parsedAmount = parseInt(amountInput.value, 10);

      if (Number.isNaN(parsedAmount) || parsedAmount < 10000) {
        alert('❌ Minimum payment is Rp 10.000');
        return;
      }
      
      fetch('/payments/create', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ merchantId, amount: parsedAmount })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          alert('✅ Payment successful! Amount: Rp ' + parsedAmount.toLocaleString('id-ID'));
          location.reload();
        } else {
          alert('❌ Payment failed: ' + data.message);
        }
      })
      .catch(err => alert('⚠️ Error: ' + err.message));
    }
  </script>

  <%- include('footer') %>
</body>
</html>

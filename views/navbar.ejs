<nav class="bg-white shadow-md sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
    <!-- LOGO -->
    <a href="/" class="text-2xl font-bold text-blue-600 hover:text-blue-800">
      💳 Cash-Cash
    </a>

    <!-- NAV CONTENT -->
    <div class="flex items-center justify-between gap-8 flex-1">
      <!-- SEARCH (CENTER) -->
      <form class="flex shadow-sm rounded-lg overflow-hidden flex-1 mx-8" action="/merchants" method="GET">
        <input
          type="text"
          name="category"
          class="flex-1 px-4 py-2 border-0 focus:outline-none"
          placeholder="Search merchants..."
        />
        <button class="bg-gray-200 hover:bg-gray-300 px-4 py-2 transition" type="submit">
          🔍
        </button>
      </form>

      <!-- BUTTONS (RIGHT) -->
      <div class="flex gap-3">
        <% if (!isAuthenticated) { %>
          <a href="/login/add" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition text-sm font-medium">Login</a>
          <a href="/register/add" class="px-4 py-2 border-2 border-blue-600 text-blue-600 rounded-lg hover:bg-blue-50 transition text-sm font-medium">Register</a>
        <% } else { %>
          <span class="text-sm font-medium text-gray-700">Hi, <strong><%= user?.name %></strong></span>
          <a href="/logout" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition text-sm font-medium">Logout</a>
        <% } %>
      </div>
    </div>
  </div>
</nav>

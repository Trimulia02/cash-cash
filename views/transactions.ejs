<%- include('header') %>
<body class="bg-gray-50">
  <%- include('navbar') %>

  <div class="max-w-4xl mx-auto px-4 py-8">
    <!-- Page Title -->
    <h1 class="text-4xl font-bold text-blue-600 mb-8">📊 Transactions</h1>

    <% const hasError = typeof error !== 'undefined' && error; %>
    <% const transactionList = typeof transactions !== 'undefined' && Array.isArray(transactions) ? transactions : []; %>
    <% const hasTransactions = transactionList.length > 0; %>
    <% const currentSort = typeof sort !== 'undefined' && sort ? sort : 'createdAt'; %>
    <% const currentOrder = typeof order !== 'undefined' && order ? order : 'DESC'; %>

    <!-- Error Message -->
    <% if (hasError) { %>
      <div class="bg-red-100 border-l-4 border-red-600 text-red-700 p-4 mb-6 rounded">
        <strong>Error:</strong> <%= error %>
      </div>
    <% } %>

    <!-- Filters -->
    <div class="bg-white rounded-lg shadow-md p-6 mb-6 flex flex-col sm:flex-row gap-4">
      <div class="flex-1">
        <label class="block text-gray-700 font-semibold mb-2">Sort By</label>
        <select id="sort" onchange="updateSort(this.value)" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600">
          <option value="createdAt" <%= currentSort === 'createdAt' ? 'selected' : '' %>>Date</option>
          <option value="amount" <%= currentSort === 'amount' ? 'selected' : '' %>>Amount</option>
          <option value="type" <%= currentSort === 'type' ? 'selected' : '' %>>Type</option>
        </select>
      </div>
      <div class="flex-1">
        <label class="block text-gray-700 font-semibold mb-2">Order</label>
        <select id="order" onchange="updateOrder(this.value)" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600">
          <option value="DESC" <%= currentOrder === 'DESC' ? 'selected' : '' %>>Newest First</option>
          <option value="ASC" <%= currentOrder === 'ASC' ? 'selected' : '' %>>Oldest First</option>
        </select>
      </div>
    </div>

    <!-- Transactions Table -->
    <% if (hasTransactions) { %>
      <div class="bg-white rounded-lg shadow-md overflow-hidden">
        <table class="w-full">
          <thead class="bg-blue-600 text-white">
            <tr>
              <th class="px-6 py-3 text-left font-semibold">Date</th>
              <th class="px-6 py-3 text-left font-semibold">Direction</th>
              <th class="px-6 py-3 text-left font-semibold">Type</th>
              <th class="px-6 py-3 text-left font-semibold">Amount</th>
              <th class="px-6 py-3 text-left font-semibold">Description</th>
            </tr>
          </thead>
          <tbody>
            <% transactionList.forEach((txn, index) => { %>
              <tr class="border-b border-gray-200 hover:bg-gray-50 transition">
                <td class="px-6 py-4"><%= new Date(txn.createdAt).toLocaleDateString('id-ID') %></td>
                <td class="px-6 py-4"><%= txn.direction || '-' %></td>
                <td class="px-6 py-4">
                  <span class="<%= txn.type === 'debit' ? 'bg-red-100 text-red-700' : 'bg-green-100 text-green-700' %> px-3 py-1 rounded text-sm font-semibold">
                    <%= txn.type.toUpperCase() %>
                  </span>
                </td>
                <td class="px-6 py-4"><strong class="<%= txn.type === 'debit' ? 'text-red-600' : 'text-green-600' %>"><%= txn.type === 'debit' ? '−' : '+' %> Rp <%= txn.amount.toLocaleString('id-ID') %></strong></td>
                <td class="px-6 py-4 text-gray-600"><%= txn.description || '-' %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if (typeof pagination !== 'undefined' && pagination) { %>
        <div class="mt-6 flex items-center justify-center gap-2">
          <% if (pagination.hasPrevPage) { %>
            <a href="?page=<%= pagination.page - 1 %>&sort=<%= currentSort %>&order=<%= currentOrder %>" class="px-4 py-2 border border-blue-600 text-blue-600 rounded-lg hover:bg-blue-50 transition">← Previous</a>
          <% } %>

          <span class="px-4 py-2 bg-blue-600 text-white rounded-lg font-semibold">Page <%= pagination.page %> of <%= pagination.pages %></span>

          <% if (pagination.hasNextPage) { %>
            <a href="?page=<%= pagination.page + 1 %>&sort=<%= currentSort %>&order=<%= currentOrder %>" class="px-4 py-2 border border-blue-600 text-blue-600 rounded-lg hover:bg-blue-50 transition">Next →</a>
          <% } %>
        </div>
      <% } %>
    <% } else { %>
      <div class="bg-white rounded-lg shadow-md p-12 text-center">
        <div class="text-5xl mb-4">📭</div>
        <p class="text-gray-500 text-lg">No transactions found</p>
        <a href="/dashboard" class="mt-4 inline-block px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">
          ← Back to Dashboard
        </a>
      </div>
    <% } %>
  </div>

  <script>
    function updateSort(value) {
      const order = new URLSearchParams(window.location.search).get('order') || 'DESC';
      window.location.href = `?sort=${value}&order=${order}`;
    }
    function updateOrder(value) {
      const sort = new URLSearchParams(window.location.search).get('sort') || 'createdAt';
      window.location.href = `?sort=${sort}&order=${value}`;
    }
  </script>

  <%- include('footer') %>
</body>
</html>

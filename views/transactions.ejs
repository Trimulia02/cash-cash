<%- include('header') %>
<body class="bg-gray-50 min-h-screen flex flex-col">
  <%- include('navbar') %>

  <div class="max-w-5xl mx-auto px-4 py-8 flex-1 w-full">
    <!-- Page Title -->
    <h1 class="text-3xl font-bold text-blue-600 mb-6">📊 Transactions</h1>

    <% const hasError = typeof error !== 'undefined' && error; %>
    <% const transactionList = typeof transactions !== 'undefined' && Array.isArray(transactions) ? transactions : []; %>
    <% const hasTransactions = transactionList.length > 0; %>

    <!-- Error Message -->
    <% if (hasError) { %>
      <div class="bg-red-100 border border-red-400 text-red-700 p-3 mb-6 rounded">
        <%= error %>
      </div>
    <% } %>

    <!-- Filters -->
    <div class="bg-white rounded-lg shadow p-4 mb-6 flex gap-2">
      <div class="flex-1">
        <select id="sort" onchange="updateSort(this.value)" class="w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-600 text-sm">
          <option value="createdAt">Sort by Date</option>
          <option value="amount">Sort by Amount</option>
          <option value="type">Sort by Type</option>
        </select>
      </div>
      <div class="flex-1">
        <select id="order" onchange="updateOrder(this.value)" class="w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-600 text-sm">
          <option value="DESC">Newest First</option>
          <option value="ASC">Oldest First</option>
        </select>
      </div>
    </div>

    <!-- Transactions Table -->
    <% if (hasTransactions) { %>
      <div class="bg-white rounded-lg shadow overflow-hidden mb-6">
        <table class="w-full">
          <thead class="bg-blue-600 text-white">
            <tr>
              <th class="px-4 py-2 text-left text-sm">Date</th>
              <th class="px-4 py-2 text-left text-sm">Direction</th>
              <th class="px-4 py-2 text-left text-sm">Type</th>
              <th class="px-4 py-2 text-left text-sm">Amount</th>
              <th class="px-4 py-2 text-left text-sm">Description</th>
            </tr>
          </thead>
          <tbody>
            <% transactionList.forEach(txn => { %>
              <tr class="border-b text-sm hover:bg-gray-50">
                <td class="px-4 py-3"><%= new Date(txn.createdAt).toLocaleDateString('id-ID') %></td>
                <td class="px-4 py-3"><%= txn.direction || '-' %></td>
                <td class="px-4 py-3">
                  <span class="<%= txn.type === 'debit' ? 'bg-red-100 text-red-700' : 'bg-green-100 text-green-700' %> px-2 py-1 rounded text-xs font-semibold">
                    <%= txn.type.toUpperCase() %>
                  </span>
                </td>
                <td class="px-4 py-3"><strong class="<%= txn.type === 'debit' ? 'text-red-600' : 'text-green-600' %>"><%= txn.type === 'debit' ? '−' : '+' %> Rp <%= txn.amount.toLocaleString('id-ID') %></strong></td>
                <td class="px-4 py-3 text-gray-600"><%= txn.description || '-' %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if (typeof pagination !== 'undefined' && pagination) { %>
        <div class="mt-4 flex justify-center gap-2">
          <% if (pagination.hasPrevPage) { %>
            <a href="?page=<%= pagination.page - 1 %>" class="px-3 py-2 border border-blue-600 text-blue-600 rounded hover:bg-blue-50 text-sm">Previous</a>
          <% } %>
          <span class="px-3 py-2 bg-blue-600 text-white rounded text-sm">Page <%= pagination.page %> of <%= pagination.pages %></span>
          <% if (pagination.hasNextPage) { %>
            <a href="?page=<%= pagination.page + 1 %>" class="px-3 py-2 border border-blue-600 text-blue-600 rounded hover:bg-blue-50 text-sm">Next</a>
          <% } %>
        </div>
      <% } %>
    <% } else { %>
      <div class="bg-white rounded-lg shadow p-8 text-center">
        <p class="text-5xl mb-4">📭</p>
        <p class="text-gray-500">No transactions found</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center mt-4">
          <a href="/transfers" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">Make Transfer</a>
          <a href="/merchants" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">Pay Merchant</a>
        </div>
      </div>
    <% } %>
  </div>

  <script>
    function updateSort(val) {
      const order = new URLSearchParams(window.location.search).get('order') || 'DESC';
      window.location.href = `?sort=${val}&order=${order}`;
    }
    function updateOrder(val) {
      const sort = new URLSearchParams(window.location.search).get('sort') || 'createdAt';
      window.location.href = `?sort=${sort}&order=${val}`;
    }
  </script>

  <%- include('footer') %>
</body>
</html>

<%- include('header') %>
<body class="bg-gray-50">
  <%- include('navbar') %>

  <div class="max-w-4xl mx-auto px-4 py-8">
    <!-- Page Title -->
    <h1 class="text-4xl font-bold text-blue-600 mb-8">🔄 Transfers</h1>

    <% const hasError = typeof error !== 'undefined' && error; %>
    <% const hasTransfers = typeof transfers !== 'undefined' && Array.isArray(transfers) && transfers.length > 0; %>
    <% const currentUserId = (typeof user !== 'undefined' && user) ? user.id : null; %>

    <!-- Error Message -->
    <% if (hasError) { %>
      <div class="bg-red-100 border-l-4 border-red-600 text-red-700 p-4 mb-6 rounded">
        <strong>Error:</strong> <%= error %>
      </div>
    <% } %>

    <!-- Transfer Form -->
    <div class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-2xl font-bold text-blue-600 mb-4">Send Money</h2>
      <form class="grid grid-cols-1 md:grid-cols-3 gap-3" onsubmit="submitTransfer(event)">
        <input
          type="number"
          name="receiverId"
          min="1"
          required
          placeholder="Receiver User ID"
          class="px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600"
        >
        <input
          type="number"
          name="amount"
          min="1000"
          required
          placeholder="Amount (min Rp 1.000)"
          class="px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600"
        >
        <button
          type="submit"
          class="px-6 py-2 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition"
        >
          Send Transfer
        </button>
      </form>
      <p class="text-sm text-gray-500 mt-3">
        Tip: gunakan User ID tujuan yang valid dan pastikan saldo cukup.
      </p>
    </div>

    <!-- Transfers List -->
    <% if (hasTransfers) { %>
      <div class="bg-white rounded-lg shadow-md overflow-hidden">
        <div class="p-6 border-b border-gray-200">
          <h2 class="text-2xl font-bold text-blue-600">Transfer History</h2>
        </div>
        <div class="divide-y">
          <% transfers.forEach(transfer => { %>
            <div class="p-6 hover:bg-gray-50 transition flex justify-between items-center">
              <div class="flex-1">
                <h3 class="text-lg font-semibold text-gray-800 mb-2">
                  <% if (transfer.senderId === currentUserId) { %>
                    <span class="text-red-600">📤 Sent to <%= transfer.receiver ? transfer.receiver.name : 'Unknown User' %></span>
                  <% } else { %>
                    <span class="text-green-600">📥 Received from <%= transfer.sender ? transfer.sender.name : 'Unknown User' %></span>
                  <% } %>
                </h3>
                <p class="text-gray-500 text-sm"><%= new Date(transfer.createdAt).toLocaleDateString('id-ID',{ weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></p>
              </div>
              <div class="text-right">
                <div class="text-2xl font-bold mb-2">
                  <% if (transfer.senderId === currentUserId) { %>
                    <span class="text-red-600">− Rp <%= transfer.amount.toLocaleString('id-ID') %></span>
                  <% } else { %>
                    <span class="text-green-600">+ Rp <%= transfer.amount.toLocaleString('id-ID') %></span>
                  <% } %>
                </div>
                <span class="<%= transfer.status === 'pending' ? 'bg-yellow-100 text-yellow-700' : transfer.status === 'completed' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %> px-3 py-1 rounded-full text-sm font-semibold">
                  <%= transfer.status.toUpperCase() %>
                </span>
              </div>
            </div>
          <% }); %>
        </div>
      </div>

      <!-- Pagination -->
      <% if (typeof pagination !== 'undefined' && pagination) { %>
        <div class="mt-6 flex items-center justify-center gap-2">
          <% if (pagination.hasPrevPage) { %>
            <a href="?page=<%= pagination.page - 1 %>" class="px-4 py-2 border border-blue-600 text-blue-600 rounded-lg hover:bg-blue-50 transition">← Previous</a>
          <% } %>

          <span class="px-4 py-2 bg-blue-600 text-white rounded-lg font-semibold">Page <%= pagination.page %> of <%= pagination.pages %></span>

          <% if (pagination.hasNextPage) { %>
            <a href="?page=<%= pagination.page + 1 %>" class="px-4 py-2 border border-blue-600 text-blue-600 rounded-lg hover:bg-blue-50 transition">Next →</a>
          <% } %>
        </div>
      <% } %>
    <% } else { %>
      <div class="bg-white rounded-lg shadow-md p-12 text-center">
        <div class="text-5xl mb-4">📭</div>
        <p class="text-gray-500 text-lg">No transfers yet</p>
        <a href="/dashboard" class="mt-4 inline-block px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">
          ← Back to Dashboard
        </a>
      </div>
    <% } %>
  </div>

  <script>
    function submitTransfer(e) {
      e.preventDefault();

      const form = e.target;
      const receiverId = parseInt(form.receiverId.value, 10);
      const amount = parseInt(form.amount.value, 10);

      if (Number.isNaN(receiverId) || receiverId < 1) {
        alert('❌ Receiver ID tidak valid');
        return;
      }

      if (Number.isNaN(amount) || amount < 1000) {
        alert('❌ Minimum transfer adalah Rp 1.000');
        return;
      }

      fetch('/transfers/create', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ receiverId, amount }),
      })
        .then(async (res) => {
          const data = await res.json().catch(() => null);
          if (!data) {
            throw new Error('Invalid server response');
          }
          return data;
        })
        .then((data) => {
          if (data.success) {
            alert('✅ Transfer berhasil: Rp ' + amount.toLocaleString('id-ID'));
            form.reset();
            location.reload();
          } else {
            alert('❌ Transfer gagal: ' + (data.message || 'Unknown error'));
          }
        })
        .catch((err) => {
          alert('⚠️ Error: ' + err.message);
        });
    }
  </script>

  <%- include('footer') %>
</body>
</html>

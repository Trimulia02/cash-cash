<%- include('header') %>
<body class="bg-gray-50 min-h-screen flex flex-col">
  <%- include('navbar') %>

  <div class="max-w-5xl mx-auto px-4 py-8 flex-1 w-full">
    <h1 class="text-3xl font-bold text-blue-600 mb-6">🔄 Transfers</h1>

    <% const hasError = typeof error !== 'undefined' && error; %>
    <% const hasTransfers = typeof transfers !== 'undefined' && Array.isArray(transfers) && transfers.length > 0; %>
    <% const currentUserId = (typeof user !== 'undefined' && user) ? user.id : null; %>

    <% if (hasError) { %>
      <div class="bg-red-100 border border-red-400 text-red-700 p-3 mb-6 rounded">
        <%= error %>
      </div>
    <% } %>

    <!-- Transfer Form -->
    <div class="bg-white rounded-lg shadow p-4 mb-6">
      <h2 class="text-lg font-bold text-blue-600 mb-3">Send Money</h2>
      <form class="flex gap-2" onsubmit="submitTransfer(event)">
        <input type="number" name="receiverId" min="1" required placeholder="User ID" class="flex-1 px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-600 text-sm">
        <input type="number" name="amount" min="1000" required placeholder="Amount" class="flex-1 px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-600 text-sm">
        <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 text-sm">Send</button>
      </form>
    </div>

    <!-- Transfers List -->
    <% if (hasTransfers) { %>
      <div class="bg-white rounded-lg shadow overflow-hidden mb-6">
        <div class="p-3 border-b bg-blue-50">
          <h2 class="text-lg font-bold text-blue-600">Transfer History</h2>
        </div>
        <div class="divide-y">
          <% transfers.forEach(transfer => { %>
            <div class="p-4 hover:bg-gray-50 flex justify-between items-center text-sm">
              <div>
                <% if (transfer.senderId === currentUserId) { %>
                  <strong class="text-red-600">📤 To <%= transfer.receiver ? transfer.receiver.name : 'User' %></strong>
                <% } else { %>
                  <strong class="text-green-600">📥 From <%= transfer.sender ? transfer.sender.name : 'User' %></strong>
                <% } %>
                <br>
                <small class="text-gray-500"><%= new Date(transfer.createdAt).toLocaleDateString('id-ID') %></small>
              </div>
              <div class="text-right">
                <% if (transfer.senderId === currentUserId) { %>
                  <span class="text-red-600 font-bold">− Rp <%= transfer.amount.toLocaleString('id-ID') %></span>
                <% } else { %>
                  <span class="text-green-600 font-bold">+ Rp <%= transfer.amount.toLocaleString('id-ID') %></span>
                <% } %>
              </div>
            </div>
          <% }); %>
        </div>
      </div>

      <!-- Pagination -->
      <% if (typeof pagination !== 'undefined' && pagination) { %>
        <div class="mt-4 flex justify-center gap-2">
          <% if (pagination.hasPrevPage) { %>
            <a href="?page=<%= pagination.page - 1 %>" class="px-3 py-2 border border-blue-600 text-blue-600 rounded hover:bg-blue-50 text-sm">Previous</a>
          <% } %>
          <span class="px-3 py-2 bg-blue-600 text-white rounded text-sm">Page <%= pagination.page %> of <%= pagination.pages %></span>
          <% if (pagination.hasNextPage) { %>
            <a href="?page=<%= pagination.page + 1 %>" class="px-3 py-2 border border-blue-600 text-blue-600 rounded hover:bg-blue-50 text-sm">Next</a>
          <% } %>
        </div>
      <% } %>
    <% } else { %>
      <div class="bg-white rounded-lg shadow p-8 text-center">
        <p class="text-5xl mb-4">📭</p>
        <p class="text-gray-500">No transfer history</p>
        <a href="/merchants" class="mt-4 inline-block px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">Pay Merchant Instead</a>
      </div>
    <% } %>
  </div>

  <script>
    function submitTransfer(e) {
      e.preventDefault();
      const receiverId = parseInt(e.target.receiverId.value, 10);
      const amount = parseInt(e.target.amount.value, 10);

      if (!receiverId || receiverId < 1 || !amount || amount < 1000) {
        alert('Invalid amount (minimum Rp 1.000)');
        return;
      }

      fetch('/transfers/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ receiverId, amount })
      }).then(res => res.json())
        .then(data => {
          if (data.success) {
            alert('Transfer successful!');
            location.reload();
          } else {
            alert('Transfer failed: ' + data.message);
          }
        }).catch(err => alert('Error: ' + err.message));
    }
  </script>

  <%- include('footer') %>
</body>
</html>
